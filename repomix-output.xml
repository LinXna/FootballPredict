        # =========================
        # Fusion Layer (Adaptive)
        # =========================
        self.fusion = LearnedFusion()

        # =========================
        # Evolution Layer
        # =========================
        self.drift_detector = DriftDetector(window_size=50)
        self.calibrator = Calibrator()

        # =========================
        # Learning hook (future RL)
        # =========================
        self.weight_updater = WeightUpdater()

    # =========================================================
    # Training
    # =========================================================

    def train(self, matches):

        for m in matches:
            self.elo.update(m["home"], m["away"], m["result"])
            self.features.train_update(m)

        self.poisson.train(matches)

    # =========================================================
    # Main Predict Entry
    # =========================================================

    def predict(self, home, away, odds=None):

        # =========================
        # 1️⃣ Base fusion prediction
        # =========================
        elo_pred = self.elo.predict(home, away)
        poi_pred = self.poisson.predict_1x2(home, away)

        base = self.fusion.fuse(elo_pred, poi_pred)

        # =========================
        # 2️⃣ Drift detection
        # =========================
        self.drift_detector.update(base)

        drift = self.drift_detector.detect()

        # =========================
        # 3️⃣ Calibration
        # =========================
        base = self.calibrator.calibrate(base)

        # =========================
        # 4️⃣ Confidence score
        # =========================
        confidence = self._confidence(base, drift)

        # =========================
        # 5️⃣ Market fusion (optional)
        # =========================
        if odds is not None:
            market_prob = odds_to_prob(odds)

            base = self._merge_market(base, market_prob)

        # =========================
        # 6️⃣ Final structured output
        # =========================
        return self._format_output(base=base, confidence=confidence, drift=drift)

    # =========================================================
    # Confidence Engine
    # =========================================================

    def _confidence(self, probs, drift):

        max_p = max(probs.values())

        entropy = -sum(
            p * (0 if p == 0 else __import__("math").log(p)) for p in probs.values()
        )

        # normalize entropy
        entropy_score = 1 / (1 + entropy)

        drift_penalty = 0.15 if drift else 0.0

        confidence = (max_p * 0.7 + entropy_score * 0.3) - drift_penalty

        return round(max(0.0, min(1.0, confidence)), 4)

    # =========================================================
    # Market fusion helper
    # =========================================================

    def _merge_market(self, model, market):

        merged = {}

        for k in ["H", "D", "A"]:

            merged[k] = 0.6 * model[k] + 0.4 * market[k]

        total = sum(merged.values())

        return {k: merged[k] / total for k in merged}

    # =========================================================
    # Output formatter (V2.0 standard)
    # =========================================================

    def _format_output(self, base, confidence, drift):

        prediction = max(base, key=base.get)

        return {
            "prediction": prediction,
            "probabilities": base,
            "confidence": confidence,
            "drift_detected": drift,
            "model": "V2.0-AI-ADAPTIVE",
            "explain": self._explain(base, confidence, drift),
        }

    # =========================================================
    # Explainability layer
    # =========================================================

    def _explain(self, probs, confidence, drift):

        explanation = []

        explanation.append("Model fusion completed (Elo + Poisson).")

        if drift:
            explanation.append("Warning: distribution drift detected.")

        explanation.append(f"Max probability: {max(probs.values()):.3f}")

        explanation.append(f"Confidence score: {confidence:.3f}")

        return explanation
