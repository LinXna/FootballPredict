import json
import os


class LearnedFusion:
    """
    V2.0 AI Adaptive Fusion Engine

    Upgrade:
    ✔ Dynamic weight injection
    ✔ Online learning compatible
    ✔ Stable V1.8 heuristics preserved
    ✔ No static coupling with trainer
    """

    def __init__(self, weight_file="data/fusion_weights.json"):

        self.weight_file = weight_file

        # 默认权重（fallback）
        self.weights = {"elo": 0.50, "poisson": 0.50}

        self._load()

    # =========================================================
    # Load / Save
    # =========================================================

    def _load(self):

        if os.path.exists(self.weight_file):

            try:
                with open(self.weight_file, "r", encoding="utf-8") as f:
                    data = json.load(f)

                if isinstance(data, dict):
                    self.weights = {
                        "elo": float(data.get("elo", 0.5)),
                        "poisson": float(data.get("poisson", 0.5)),
                    }

            except Exception:
                pass

    def _save(self):

        os.makedirs(os.path.dirname(self.weight_file), exist_ok=True)

        with open(self.weight_file, "w", encoding="utf-8") as f:
            json.dump(self.weights, f, indent=4)

    # =========================================================
    # Public API
    # =========================================================

    def get_weights(self):
        return dict(self.weights)

    def set_weights(self, weights: dict):

        if not weights:
            return

        if "elo" in weights:
            self.weights["elo"] = float(weights["elo"])

        if "poisson" in weights:
            self.weights["poisson"] = float(weights["poisson"])

        self._normalize()
        self._save()

    # =========================================================
    # Core Fusion (V2.0)
    # =========================================================

    def fuse(self, elo_pred, poisson_pred):

        result = {}

        for k in ["H", "D", "A"]:

            if k not in elo_pred or k not in poisson_pred:
                continue

            result[k] = (
                self.weights["elo"] * elo_pred[k]
                + self.weights["poisson"] * poisson_pred[k]
            )

        # =====================================================
        # V1.8 Stability Patch (preserved)
        # =====================================================

        if "H" in result and "A" in result:

            gap = result["H"] - result["A"]

            if abs(gap) < 0.015:

                result["H"] *= 1.03
                result["A"] *= 1.03
                result["D"] *= 0.92

        # Draw suppression heuristic (legacy but stable)
        if "D" in result:
            result["D"] *= 0.92

        # =====================================================
        # Stability normalization
        # =====================================================

        for k in result:
            result[k] = max(result[k], 1e-9)

        total = sum(result.values())

        return {
            "H": result["H"] / total,
            "D": result["D"] / total,
            "A": result["A"] / total,
        }

    # =========================================================
    # Normalization
    # =========================================================

    def _normalize(self):

        self.weights["elo"] = max(0.05, self.weights["elo"])
        self.weights["poisson"] = max(0.05, self.weights["poisson"])

        total = self.weights["elo"] + self.weights["poisson"]

        self.weights["elo"] /= total
        self.weights["poisson"] /= total

    # =========================================================
    # Debug
    # =========================================================

    def __repr__(self):

        return f"LearnedFusion(weights={self.weights})"
